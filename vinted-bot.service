[Unit]
Description=Vinted Swear Bot
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/vinted-bot
ExecStart=/usr/bin/python3 /home/ubuntu/vinted-bot/main.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONIOENCODING=utf-8

[Install]
WantedBy=multi-user.target
